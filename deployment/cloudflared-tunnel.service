# /etc/systemd/system/cloudflared-tunnel.service
[Unit]
Description=Cloudflare Tunnel (lifedashboard-wsl)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=angrymusic
ExecStart=/usr/bin/cloudflared tunnel --config /home/angrymusic/.cloudflared/config.yml run lifedashboard-wsl
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target